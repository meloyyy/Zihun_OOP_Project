<Window x:Class="Zihun_OOP_Project_2026.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Платформа онлайн-курсів" Height="720" Width="1120"
        WindowStartupLocation="CenterScreen" Background="{StaticResource LightMintBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="86"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryBlueBrush}" Padding="24,12">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Online Courses Desktop" FontSize="28" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Desktop-застосунок платформи онлайн-курсів засобами C# WPF" Foreground="#CFF7F2"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Роль:" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="RoleComboBox" Width="185" SelectedIndex="0" SelectionChanged="RoleComboBox_SelectionChanged">
                        <ComboBoxItem Content="Гість"/>
                        <ComboBoxItem Content="Зареєстрований користувач"/>
                    </ComboBox>
                    <Button Content="Зберегти JSON" Click="SaveButton_Click" Background="{StaticResource AccentCyanBrush}"/>
                    <Button Content="Завантажити JSON" Click="LoadButton_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="16" Padding="16" Margin="0,0,14,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="Каталог курсів" FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryBlueBrush}"/>
                        <TextBox x:Name="SearchTextBox" TextChanged="SearchTextBox_TextChanged" Margin="0,14,0,10" Height="38"
                                 ToolTip="Введіть назву курсу для пошуку"/>
                        <Button Content="Показати мої курси" Click="MyCoursesButton_Click"/>
                        <Button Content="Показати всі курси" Click="AllCoursesButton_Click"/>
                    </StackPanel>

                    <ListBox x:Name="CoursesListBox" SelectionChanged="CoursesListBox_SelectionChanged" Margin="0,14,0,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#D8EDEA" BorderThickness="0,0,0,1" Padding="8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="15" Foreground="{StaticResource PrimaryBlueBrush}" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Category}" Foreground="{StaticResource PrimaryGreenBrush}"/>
                                        <TextBlock Text="{Binding DurationHours, StringFormat=Тривалість: {0} год.}" FontSize="12"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="16" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock x:Name="CourseTitleTextBlock" Text="Оберіть курс" FontSize="26" FontWeight="Bold" Foreground="{StaticResource PrimaryBlueBrush}" TextWrapping="Wrap"/>
                        <TextBlock x:Name="CourseInfoTextBlock" Margin="0,8,0,0" FontSize="15" Foreground="#355" TextWrapping="Wrap"/>
                        <TextBlock x:Name="CourseDescriptionTextBlock" Margin="0,10,0,0" FontSize="15" TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,16,0,12">
                        <Button x:Name="EnrollButton" Content="Записатися на курс" Click="EnrollButton_Click"/>
                        <TextBlock Text="Прогрес:" VerticalAlignment="Center" Margin="18,0,8,0" FontWeight="SemiBold"/>
                        <ProgressBar x:Name="ProgressBar" Width="260" Height="22" Minimum="0" Maximum="100"/>
                        <TextBlock x:Name="ProgressTextBlock" VerticalAlignment="Center" Margin="8,0,0,0" FontWeight="Bold" Foreground="{StaticResource PrimaryGreenBrush}"/>
                    </StackPanel>

                    <GroupBox Grid.Row="2" Header="Модулі курсу" FontWeight="Bold" Foreground="{StaticResource PrimaryBlueBrush}">
                        <ListBox x:Name="ModulesListBox" Margin="8">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10" BorderBrush="#D8EDEA" BorderThickness="0,0,0,1">
                                        <DockPanel>
                                            <CheckBox DockPanel.Dock="Left" IsChecked="{Binding IsCompleted}" Checked="ModuleCheckBox_Changed" Unchecked="ModuleCheckBox_Changed"
                                                      VerticalAlignment="Top" Margin="0,3,10,0"/>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryGreenBrush}"/>
                                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Foreground="#333"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </GroupBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
